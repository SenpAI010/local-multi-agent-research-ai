# Optional: override local Ollama model roles.
# Copy to .env only if you use a dotenv loader yourself; the current launcher
# mainly uses normal environment variables.

LOCAL_AGENT_CHIEF_MODEL=qwen3:30b
LOCAL_AGENT_REASONING_MODEL=deepseek-r1:70b
LOCAL_AGENT_CODING_MODEL=qwen3-coder:30b
LOCAL_AGENT_VISION_MODEL=llama3.2-vision:90b
LOCAL_AGENT_VISION_BACKUP_MODEL=llama3.2-vision:90b

# Set to 1 if you want proactive screen alerts printed in the CLI.
LOCAL_AGENT_SCREEN_ALERTS=0

